generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DataType {
  Default
  Demo
}

model Project {
  id            String   @id @default(cuid())
  name          String
  clientName    String
  clientNumber  String?
  projectLinks  String?
  projectType   String
  status        String
  plannedAmount Decimal  @db.Decimal(12, 2)
  totalPaid     Decimal  @default(0) @db.Decimal(12, 2)
  type          DataType @default(Default)

  payments Payment[]
  notes    ProjectNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String
  reference     String?
  notes         String?
  paymentDate   DateTime
  type          DataType @default(Default)
  createdAt     DateTime @default(now())
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content   String
  type      DataType @default(Default)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Credential {
  id          String   @id @default(cuid())
  serviceName String
  websiteUrl  String
  username    String
  password    String
  category    String
  notes       String?
  type        DataType @default(Default)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinanceRecord {
  id                 String   @id @default(cuid())
  moduleType         String
  name               String
  amount             Decimal  @db.Decimal(12, 2)
  totalAmount        Decimal? @db.Decimal(12, 2)
  dueDay             Int?
  totalMonths        Int?
  remainingMonths    Int?
  currentInstallment Int?
  startDate          DateTime?
  websiteUrl         String?
  billingCycle       String?
  renewalDate        DateTime?
  autoRenew          Boolean  @default(true)
  category           String?
  notes              String?
  type               DataType @default(Default)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  payments FinancePaymentHistory[]
}

model FinancePaymentHistory {
  id                   String        @id @default(cuid())
  recordId             String
  record               FinanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  amount               Decimal       @db.Decimal(12, 2)
  dueDate              DateTime
  paidDate             DateTime?
  status               String
  periodLabel          String?
  installmentNumber    Int?
  notes                String?
  transactionReference String?
  createdBy            String?
  type                 DataType      @default(Default)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Budget {
  id        String           @id @default(cuid())
  month     Int
  year      Int
  income    Decimal          @db.Decimal(12, 2)
  ruleType  String
  ruleLabel String
  notes     String?
  status    String           @default("Active")
  type      DataType         @default(Default)
  categories BudgetCategory[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type, year, month, status])
}

model BudgetCategory {
  id            String   @id @default(cuid())
  budgetId      String
  budget        Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name          String
  percentage    Decimal  @db.Decimal(5, 2)
  plannedAmount Decimal  @db.Decimal(12, 2)
  actualAmount  Decimal  @default(0) @db.Decimal(12, 2)
  financeLink   String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
